# .env.example — Agent 协作平台 API Key 配置
# 使用方法: cp .env.example .env && vi .env && source .env
# 或者: export COLLAB_API_KEY_YIHAO="your_key_here"

# 平台地址 (默认: https://eye.auto-claw.top:3847)
# COLLAB_URL=https://eye.auto-claw.top:3847

# Agent API Key — 从 agents/registry.json 里拿
# COLLAB_API_KEY_DAQIN=agent_daqin_secret_key_2025
# COLLAB_API_KEY_YIHAO=agent_yihao_secret_key_2025
# COLLAB_API_KEY_XIAOBAI=agent_xiaobai_secret_key_2025
# COLLAB_API_KEY_GUWEN=agent_guwen_secret_key_2025

# SSL 验证 (自签证书场景)
# VERIFY_SSL=false

# 离线模式 (不真发请求)
# COLLAB_SIMULATE=1
# COLLAB_SIMULATE_DB=/tmp/collab_sim.jsonl
